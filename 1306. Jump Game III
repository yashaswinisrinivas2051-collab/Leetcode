class Solution:
    def canReach(self, arr, start):
        n = len(arr)
        visited = set()

        def dfs(i):
            # Check boundaries and visited indices
            if i < 0 or i >= n or i in visited:
                return False

            # If value is 0, return True
            if arr[i] == 0:
                return True

            visited.add(i)

            # Jump forward or backward
            return dfs(i + arr[i]) or dfs(i - arr[i])

        return dfs(start)
