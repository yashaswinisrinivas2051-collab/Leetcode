class Solution:
    def minOperations(self, s: str) -> int:
        count_start_0 = 0
        count_start_1 = 0
        
        for i in range(len(s)):
            expected0 = '0' if i % 2 == 0 else '1'
            expected1 = '1' if i % 2 == 0 else '0'
            
            if s[i] != expected0:
                count_start_0 += 1
                
            if s[i] != expected1:
                count_start_1 += 1
        
        return min(count_start_0, count_start_1)
        
