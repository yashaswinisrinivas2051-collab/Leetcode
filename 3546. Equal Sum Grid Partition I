from typing import List

class Solution:
    def canPartitionGrid(self, grid: List[List[int]]) -> bool:
        m = len(grid)
        n = len(grid[0])

        # Step 1: Calculate total sum
        total = sum(sum(row) for row in grid)

        # If total sum is odd, cannot split equally
        if total % 2 != 0:
            return False

        target = total // 2

        # Step 2: Check horizontal cuts
        curr_sum = 0
        for i in range(m - 1):
            curr_sum += sum(grid[i])
            if curr_sum == target:
                return True

        # Step 3: Compute column sums
        col_sums = [0] * n
        for i in range(m):
            for j in range(n):
                col_sums[j] += grid[i][j]

        # Step 4: Check vertical cuts
        curr_sum = 0
        for j in range(n - 1):
            curr_sum += col_sums[j]
            if curr_sum == target:
                return True

        return False
