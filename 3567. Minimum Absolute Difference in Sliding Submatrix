from typing import List
class Solution:
    def minAbsDiff(self, grid: List[List[int]], k: int) -> List[List[int]]:
        m, n = len(grid), len(grid[0])
        # Result matrix
        ans = [[0] * (n - k + 1) for _ in range(m - k + 1)]
        for i in range(m - k + 1):
            for j in range(n - k + 1):
                # Step 1: Collect elements of k x k submatrix
                elements = []
                for x in range(i, i + k):
                    for y in range(j, j + k):
                        elements.append(grid[x][y])
                
                # Step 2: Get unique values
                unique_vals = sorted(set(elements))
                
                # Step 3: If only one value → 0
                if len(unique_vals) == 1:
                    ans[i][j] = 0
                    continue
                
                # Step 4: Find minimum absolute difference
                min_diff = float('inf')
                for t in range(1, len(unique_vals)):
                    diff = unique_vals[t] - unique_vals[t - 1]
                    min_diff = min(min_diff, diff)
                
                ans[i][j] = min_diff
        
        return ans
