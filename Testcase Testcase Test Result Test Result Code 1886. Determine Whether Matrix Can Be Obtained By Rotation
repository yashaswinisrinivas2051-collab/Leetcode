from typing import List

class Solution:
    def findRotation(self, mat: List[List[int]], target: List[List[int]]) -> bool:
        
        # Function to rotate matrix 90° clockwise
        def rotate(matrix):
            n = len(matrix)
            return [[matrix[n - j - 1][i] for j in range(n)] for i in range(n)]
        
        # Try all 4 rotations
        for _ in range(4):
            if mat == target:
                return True
            mat = rotate(mat)
        
        return False
