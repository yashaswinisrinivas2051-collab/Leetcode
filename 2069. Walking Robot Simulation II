class Robot:

    def __init__(self, width: int, height: int):
        self.w = width
        self.h = height
        self.x = 0
        self.y = 0
        self.dir = 0  # 0=East, 1=North, 2=West, 3=South
        
        self.directions = ["East", "North", "West", "South"]
        
        # total cycle (perimeter)
        self.perimeter = 2 * (self.w + self.h) - 4

    def step(self, num: int) -> None:
        num %= self.perimeter
        
        # Special case: if num == 0, robot should face South at (0,0)
        if num == 0:
            if self.x == 0 and self.y == 0:
                self.dir = 3  # South
            return
        
        while num > 0:
            if self.dir == 0:  # East
                steps = min(num, self.w - 1 - self.x)
                self.x += steps
                num -= steps
                if num > 0:
                    self.dir = 1  # turn North

            elif self.dir == 1:  # North
                steps = min(num, self.h - 1 - self.y)
                self.y += steps
                num -= steps
                if num > 0:
                    self.dir = 2  # turn West

            elif self.dir == 2:  # West
                steps = min(num, self.x)
                self.x -= steps
                num -= steps
                if num > 0:
                    self.dir = 3  # turn South

            else:  # South
                steps = min(num, self.y)
                self.y -= steps
                num -= steps
                if num > 0:
                    self.dir = 0  # turn East

    def getPos(self) -> list:
        return [self.x, self.y]

    def getDir(self) -> str:
        return self.directions[self.dir]
