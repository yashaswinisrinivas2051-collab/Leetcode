class Solution:
    def canReach(self, s: str, minJump: int, maxJump: int) -> bool:
        n = len(s)
        
        # queue for BFS
        queue = [0]
        
        # farthest index already checked
        farthest = 0
        
        while queue:
            i = queue.pop(0)
            
            # possible jump range
            start = max(i + minJump, farthest + 1)
            end = min(i + maxJump, n - 1)
            
            for j in range(start, end + 1):
                if s[j] == '0':
                    if j == n - 1:
                        return True
                    queue.append(j)
            
            farthest = end
        
        return n == 1
