class Solution:
    def minJumps(self, arr: List[int]) -> int:
        n = len(arr)

        # If already at last index
        if n == 1:
            return 0

        # Store indices having same value
        graph = defaultdict(list)

        for i, value in enumerate(arr):
            graph[value].append(i)

        # BFS setup
        queue = deque([0])
        visited = [False] * n
        visited[0] = True

        steps = 0

        while queue:
            size = len(queue)

            for _ in range(size):
                current = queue.popleft()

                # Reached last index
                if current == n - 1:
                    return steps

                neighbors = []

                # i - 1
                if current - 1 >= 0:
                    neighbors.append(current - 1)

                # i + 1
                if current + 1 < n:
                    neighbors.append(current + 1)

                # Same value indices
                neighbors.extend(graph[arr[current]])

                # Visit all neighbors
                for next_index in neighbors:
                    if not visited[next_index]:
                        visited[next_index] = True
                        queue.append(next_index)

                # Clear list to avoid repeated processing
                graph[arr[current]].clear()

            steps += 1

        return -1
